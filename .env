# ============================================================
# .env — non-secret defaults
# Committed to git. Do NOT put passwords or keys here.
# Secrets and local overrides belong in .env.local (git-ignored).
# ============================================================

# ── Local Variables ──────────────────────────────────────────
BASE_DIR=.

# ── Versions ─────────────────────────────────────────────────
MINIO_VERSION=RELEASE.2025-07-23T15-54-02Z
POSTGRES_VERSION=16-alpine
ICEBERG_REST_VERSION=1.6.0
TRINO_VERSION=435
NGINX_IMAGE_TAG=1.27-alpine

# ── Ports ────────────────────────────────────────────────────
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_PORT=5432
ICEBERG_REST_PORT=8181
TRINO_PORT=8080
AIRFLOW_API_SERVER_PORT=8081
FLUENTD_PORT=24224
NGINX_PORT=80

# ── MinIO ────────────────────────────────────────────────────
MINIO_BUCKETS=airflow-logs,airflow-data,iceberg-warehouse

# ── AWS / region (used by Iceberg REST + Trino) ──────────────
AWS_REGION=us-east-1

# ── Airflow ──────────────────────────────────────────────────
AIRFLOW_VAR_ENVIRONMENT=local
AIRFLOW__WEBSERVER__BASE_URL=http://localhost/airflow

